# Wallet private key (never commit the real .env file)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Across mainnet API (rate-limited access without API key)
ACROSS_API_URL=https://app.across.to/api

# Coinbase CDP Onramp (production)
COINBASE_API_KEY_ID=YOUR_COINBASE_API_KEY_ID_HERE
COINBASE_API_KEY_SECRET=YOUR_COINBASE_API_KEY_SECRET_HERE
